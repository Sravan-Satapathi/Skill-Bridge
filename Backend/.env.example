# Database
DB_URL=jdbc:mysql://localhost:3306/skillbridge
DB_USERNAME=db-username
DB_PASSWORD=db-password

# JWT
JWT_SECRET_KEY=secret-key

# AI (Groq - OpenAI-compatible)
